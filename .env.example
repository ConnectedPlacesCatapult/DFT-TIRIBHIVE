# TRIB / HIVE Environment Variables
# Same names work on Vercel dashboard and Azure Application Settings

# Database -- Phase A: Supabase connection string | Phase B: Azure Postgres
DATABASE_URL=

# Supabase -- retained both phases for pgvector
SUPABASE_URL=
SUPABASE_ANON_KEY=

# AI -- embeddings + report synthesis
OPENAI_API_KEY=

# App -- Phase A: Vercel URL | Phase B: trib.org.uk
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node
NODE_ENV=development
